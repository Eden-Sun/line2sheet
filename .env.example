# LINE（必填）
LINE_CHANNEL_SECRET=你的_channel_secret

# LINE（選填）— 沒填的話傳送者欄位顯示 userId，而不是名稱
LINE_CHANNEL_ACCESS_TOKEN=

# Google Sheet（必填）
SPREADSHEET_ID=試算表網址 /d/ 後面那串
SHEET_NAME=Sheet1

# Google 認證（本機專用）— Vercel 請用 GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# 本機 port（選填，預設 3000）
PORT=3000
